---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} | Kanal Fuchs Blog`}
  description={post.data.description}
  canonical={`https://kanal-fuchs.de/blog/${post.id}`}
>

    <!-- Hero Banner -->
    <section style="background: linear-gradient(135deg, #1B3A52 0%, #2a5478 100%); padding: 70px 0 50px; text-align: center;">
        <div class="container">
            <p style="color: #E85D1C; font-weight: 600; font-size: 0.9rem; margin: 0 0 12px; text-transform: uppercase; letter-spacing: 0.08em;">
                {post.data.date.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })} · {post.data.author}
            </p>
            <h1 style="color: #fff; font-size: 2.4rem; margin: 0; line-height: 1.3; max-width: 800px; margin: 0 auto;">{post.data.title}</h1>
        </div>
    </section>

    {post.data.image && (
        <div style="background: #f4f8fb; padding: 40px 0 0;">
            <div class="container">
                <img
                    src={post.data.image}
                    alt={post.data.imageAlt ?? post.data.title}
                    style="width: 100%; max-height: 460px; object-fit: cover; border-radius: 8px;"
                >
            </div>
        </div>
    )}

    <!-- Article Content -->
    <article style="padding: 60px 0; background: #f4f8fb;">
        <div class="container">
            <div style="max-width: 780px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 48px 52px; box-shadow: 0 2px 16px rgba(0,0,0,0.07);">
                <div class="blog-content">
                    <Content />
                </div>
                <div style="margin-top: 48px; padding-top: 32px; border-top: 2px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; flex-wrap: gap: 16px;">
                    <a href="/blog" style="color: #1B3A52; font-weight: 600; text-decoration: none;">← Alle Artikel</a>
                    <a href="tel:060038276464" style="background: #E85D1C; color: #fff; padding: 12px 24px; border-radius: 4px; font-weight: 700; text-decoration: none;">Jetzt anrufen</a>
                </div>
            </div>
        </div>
    </article>

</Layout>

<style>
.blog-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #333;
}
.blog-content h2 {
    color: #1B3A52;
    font-size: 1.6rem;
    margin: 2rem 0 1rem;
}
.blog-content h3 {
    color: #1B3A52;
    font-size: 1.25rem;
    margin: 1.6rem 0 0.8rem;
}
.blog-content p {
    margin: 0 0 1.2rem;
}
.blog-content ul, .blog-content ol {
    margin: 0 0 1.2rem 1.5rem;
}
.blog-content li {
    margin-bottom: 0.5rem;
}
.blog-content strong {
    color: #1B3A52;
}
.blog-content a {
    color: #E85D1C;
    text-decoration: underline;
}
</style>
