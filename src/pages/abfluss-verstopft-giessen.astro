                            <label for="message">Ihre Nachricht *</label>
                            <textarea id="message" name="message" required></textarea>
                        </div>
                        <button type="submit" class="submit-button">Anfrage senden</button>
                    </form>
                </div>
                <div class="contact-info">
                    <div class="contact-item">
                        <div class="contact-icon">📞</div>
                        <div class="contact-details">
                            <h3>Telefon</h3>
                            <p><a href="tel:060038276464">06003 / 8276464</a><br>Notdienst 24/7</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon">✉️</div>
                        <div class="contact-details">
                            <h3>E-Mail</h3>
                            <p><a href="mailto:info@kanal-fuchs.de">info@kanal-fuchs.de</a></p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon">📍</div>
                        <div class="contact-details">
                            <h3>Adresse</h3>
                            <p>Konrad-Adenauer-Str. 5a<br>61191 Rosbach</p>
                        </div>
                    </div>
                </div>
            </div>
            <p style="text-align: center; max-width: 820px; margin: 40px auto 0; color: #555; font-size: 0.95rem; line-height: 1.7;">
                <strong>Einsatzgebiet:</strong> Gießen – Innenstadt, Nordstadt, Südstadt, Wieseck, Klein-Linden, Lützellinden, Rödgen, Allendorf – sowie Heuchelheim, Linden, Pohlheim, Buseck, Fernwald, Lollar, Wettenberg, Staufenberg, Wetzlar und Marburg. Auch das übrige Mittelhessen und das Rhein-Main-Gebiet gehören zu unserem Einsatzgebiet.
            </p>
        </div>
    </section>

</Layout>
