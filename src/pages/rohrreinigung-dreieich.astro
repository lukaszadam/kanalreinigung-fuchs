---
import Layout from '../layouts/Layout.astro';
import { dreieich as d } from '../data/rohrreinigung-dreieich';
---

<Layout
  title={d.meta.title}
  description={d.meta.description}
  canonical={d.meta.canonical}
>

    <!-- Hero Banner -->
    <section style="background: linear-gradient(135deg, #1B3A52 0%, #2a5478 100%); padding: 80px 0 60px; text-align: center;">
        <div class="container">
            <h1 style="color: #fff; font-size: 2.8rem; margin-bottom: 16px; line-height: 1.2;">{d.hero.heading}</h1>
            <p style="color: rgba(255,255,255,0.85); font-size: 1.2rem; max-width: 650px; margin: 0 auto 30px;">{d.hero.subtext}</p>
            <a href={`tel:${d.hero.phone}`} style="display: inline-block; background: #E85D1C; color: #fff; padding: 16px 36px; border-radius: 4px; font-weight: 700; font-size: 1.1rem; text-decoration: none;">Jetzt anrufen: {d.hero.phoneDisplay}</a>
        </div>
    </section>

    <!-- Intro -->
    <section class="intro-section">
        <div class="container">
            <div class="intro-content">
                <div class="intro-text">
                    <h2>{d.intro.heading}</h2>
                    {d.intro.paragraphs.map(p => <p set:html={p} />)}
                </div>
                <div class="intro-image">
                    <img src={d.intro.image.src} alt={d.intro.image.alt}>
                </div>
            </div>
        </div>
    </section>

    <!-- Foto Gallery -->
    <section style="padding: 50px 0; background: #f4f8fb;">
        <div class="container">
            <div style="display: flex; justify-content: center;">
                <img src={d.galleryImage.src} alt={d.galleryImage.alt} style="width: 100%; max-width: 520px; height: 280px; object-fit: cover; border-radius: 4px;">
            </div>
        </div>
    </section>

    <!-- Black Banner -->
    <section class="black-banner">
        <div class="container">
            <div class="banner-content">
                <h2>{d.blackBanner}</h2>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section class="cards-section">
        <div class="container">
            <h2 style="text-align: center; font-size: 2.2rem; color: #1B3A52; margin-bottom: 50px;">{d.services.heading}</h2>
            <div class="cards-grid">
                {d.services.cards.map(card => (
                    <div class="card">
                        <div class="icon">{card.icon}</div>
                        <h3>{card.title}</h3>
                        <p set:html={card.text} />
                        {card.link && (
                            <a href={card.link.href} style="display: inline-block; margin-top: 12px; color: #E85D1C; font-weight: 600; text-decoration: none;">{card.link.label}</a>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Erweiterte Leistungen -->
    <section style="background: #fff; padding: 70px 0;">
        <div class="container">
            <h2 style="text-align: center; font-size: 2.2rem; color: #1B3A52; margin-bottom: 16px;">{d.extendedServices.heading}</h2>
            <p style="text-align: center; max-width: 700px; margin: 0 auto 50px; color: #555; font-size: 1.05rem;">{d.extendedServices.subtext}</p>
            <div class="cards-grid">
                {d.extendedServices.cards.map(card => (
                    <div class="card">
                        <div class="icon">{card.icon}</div>
                        <h3>{card.title}</h3>
                        <p set:html={card.text} />
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Ortsteile -->
    <section style="background: #fff; padding: 60px 0;">
        <div class="container">
            <h2 style="text-align: center; font-size: 2.2rem; color: #1B3A52; margin-bottom: 20px;">{d.ortsteile.heading}</h2>
            <p style="text-align: center; max-width: 750px; margin: 0 auto 40px; color: #555; font-size: 1.05rem;">{d.ortsteile.subtext}</p>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
                {d.ortsteile.items.map(item => (
                    <div style="background: #f4f8fb; border-left: 4px solid #E85D1C; padding: 20px 24px; border-radius: 4px;">
                        <h3 style="color: #1B3A52; font-size: 1.1rem; margin-bottom: 8px;">{item.name}</h3>
                        <p style="color: #555; font-size: 0.95rem; margin: 0;">{item.text}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Why Us -->
    <section class="why-us-section">
        <div class="container">
            <h2>{d.whyUs.heading}</h2>
            <div class="why-us-grid">
                {d.whyUs.items.map(item => (
                    <div class="why-us-item">
                        <div class="why-us-icon">{item.icon}</div>
                        <h3>{item.title}</h3>
                        <p>{item.text}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section style="background: #f4f8fb; padding: 70px 0;">
        <div class="container">
            <h2 style="text-align: center; font-size: 2.2rem; color: #1B3A52; margin-bottom: 12px;">{d.faq.heading}</h2>
            <p style="text-align: center; max-width: 650px; margin: 0 auto 48px; color: #555; font-size: 1.05rem;">{d.faq.subtext}</p>
            <div style="max-width: 820px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px;">
                {d.faq.items.map(item => (
                    <details style="background: #fff; border-radius: 6px; border: 1px solid #e0e8f0; overflow: hidden;">
                        <summary style="padding: 22px 28px; font-size: 1.1rem; font-weight: 700; color: #1B3A52; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 12px;">
                            {item.question}
                            <span style="font-size: 1.4rem; color: #E85D1C; flex-shrink: 0; line-height: 1;">+</span>
                        </summary>
                        <div style="padding: 0 28px 22px; color: #444; font-size: 1rem; line-height: 1.7; border-top: 1px solid #e0e8f0;">
                            <p style="margin: 16px 0 0;" set:html={item.answer} />
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": d.faq.items.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer.replace(/<[^>]+>/g, '')
        }
      }))
    })}></script>

    <!-- Orange Banner -->
    <section class="orange-banner">
        <div class="container">
            <div class="banner-text">
                <h2>{d.orangeBanner.heading}</h2>
                <p>{d.orangeBanner.text} <a href={`tel:${d.orangeBanner.phone}`} style="color: white; font-weight: 700;">{d.orangeBanner.phoneDisplay}</a> {d.orangeBanner.contactLink}</p>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="contact-section" id="kontakt">
        <div class="container">
            <h2>{d.contact.heading}</h2>
            <div class="contact-wrapper" style="display: flex; justify-content: center;">
                <div class="contact-form" style="width: 100%; max-width: 600px;">
                    <form name={d.contact.formName} method="POST" data-netlify="true">
                        <div class="form-group">
                            <label for="name">Name *</label>
                            <input type="text" id="name" name="name" required>
                        </div>
                        <div class="form-group">
                            <label for="email">E-Mail *</label>
                            <input type="email" id="email" name="email" required>
                        </div>
                        <div class="form-group">
                            <label for="phone">Telefonnummer</label>
                            <input type="tel" id="phone" name="phone">
                        </div>
                        <div class="form-group">
                            <label for="message">Ihre Nachricht *</label>
                            <textarea id="message" name="message" required></textarea>
                        </div>
                        <button type="submit" class="submit-button">Anfrage senden</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</Layout>
