>

    <script type="application/ld+json" is:inline>{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was kostet eine TV-Inspektion in Frankfurt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Das hängt von Länge und Zugänglichkeit der Leitungen ab. Sie bekommen von uns vorab einen Festpreis – rufen Sie an und schildern Sie kurz Ihr Objekt, dann nennen wir Ihnen den Preis direkt am Telefon."
          }
        },
        {
          "@type": "Question",
          "name": "Muss dafür etwas aufgegraben werden?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. Die Kamera wird über vorhandene Zugänge eingeführt – Revisionsschacht, Reinigungsöffnung oder Abfluss. Ihr Garten und Ihre Böden bleiben unangetastet."
          }
        },
        {
          "@type": "Question",
          "name": "Wie lange dauert eine Kanalinspektion?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Bei einem typischen Einfamilienhaus in der Regel ein bis zwei Stunden inklusive Spülung und Dokumentation."
          }
        },
        {
          "@type": "Question",
          "name": "Bekomme ich die Aufnahmen der Inspektion?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja, immer. Video und Bericht gehören zum Leistungsumfang – Sie können beides für Versicherung, Kaufverhandlung oder als Grundlage für Sanierungsangebote verwenden."
          }
        },
        {
          "@type": "Question",
          "name": "Was passiert, wenn ihr einen Schaden findet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dann erklären wir Ihnen ehrlich, wie gravierend er ist und welche Optionen es gibt – von Beobachten über punktuelle grabenlose Sanierung bis zur Erneuerung. Die Entscheidung liegt bei Ihnen, ohne Zeitdruck."
          }
        }
      ]
    }</script>

